# Heidi Desktop E2E — xa11y test config
# Copy to .env.e2e (gitignored) and fill in your password:
#   cp .env.e2e.example .env.e2e
#
# Only the password is needed for the FIRST login. After that the Auth0
# token persists and later runs skip the login flow entirely.

HEIDI_E2E_EMAIL=benny@heidihealth.com
HEIDI_E2E_PASSWORD=your-password-here

# --- Which Heidi build to test (optional — defaults shown) --------------
# App NAME and PATH must be set as a PAIR: PATH decides which bundle
# `open` launches; NAME is used by activate / by_name to attach + bring it
# frontmost. Mismatched pair = "launch A but attach B".
#
# If you only ever test one build, uncomment + set these here. If you SWITCH
# between prod/staging (different bundle names on this machine), prefer the
# per-env files instead:  source env/staging.env  /  source env/prod.env
#
# HEIDI_APP_NAME=Heidi
# HEIDI_APP_PATH=/Applications/Heidi.app
# XA11Y_DEFAULT_TIMEOUT=10
